{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev: setup + start (Mac)",
      "type": "shell",
      "command": "bash scripts/dev-mac.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "dev: smoke test",
      "type": "shell",
      "command": "bash scripts/smoke-test-mac.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "dev: pytest",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/pytest tests/ -q",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
