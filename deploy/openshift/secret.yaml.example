# Copy to secret.yaml and set a strong password, or create via CLI:
#   oc create secret generic vcenteremu-secret \
#     --from-literal=VCENTEREMU_API_PASSWORD='YourSecurePassword' \
#     -n vcenteremu
apiVersion: v1
kind: Secret
metadata:
  name: vcenteremu-secret
  labels:
    app.kubernetes.io/name: vcenteremu
type: Opaque
stringData:
  VCENTEREMU_API_PASSWORD: "ChangeMe-Emulator123!"
